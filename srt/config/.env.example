# Contents of /srt/srt/config/.env.example

# Example environment configuration for the Real-Time Shuttle Tracking Platform

# Database configuration
DATABASE_URL=postgres://username:password@localhost:5432/shuttle_tracking?sslmode=disable

# Redis configuration
REDIS_URL=redis://localhost:6379

# NATS configuration
NATS_URL=nats://localhost:4222

# JWT configuration
JWT_SECRET=your_jwt_secret
JWT_EXPIRATION=24h

# OTP configuration
OTP_EXPIRY_DURATION=5m
OTP_SESSION_TIMEOUT=10m

# Trip configuration
TRIP_IDLE_TIMEOUT=15m
AUTO_END_THRESHOLD=10m

# Location update rate limit
LOCATION_RATE_LIMIT=5s

# Server configuration
SERVER_PORT=8080

# Logging configuration
LOG_LEVEL=info

# Observability configuration
OTEL_SERVICE_NAME=shuttle_tracking_service
OTEL_EXPORTER=stdout

# Health check configuration
HEALTH_CHECK_INTERVAL=30s

# Other configurations
CONFIG_VERSION=1.0.0